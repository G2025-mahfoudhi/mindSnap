<aside class="border-end bg-light d-flex flex-column" style="width: 260px; min-width: 260px;">
  <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
    <%= link_to "Mon espace", espaces_path, class: "fw-semibold small text-decoration-none text-dark" %>
    <%= link_to new_document_path,
                class: "btn btn-sm btn-primary",
                aria: { label: "Nouveau document" } do %>
      <i class="fa-solid fa-plus"></i>
    <% end %>
  </div>

  <div class="overflow-auto flex-grow-1 py-2">
    <% folders.each do |folder| %>
      <div class="px-3 py-1">
        <div class="d-flex align-items-center gap-2 text-muted fw-semibold text-uppercase mb-1"
             style="font-size: 11px; letter-spacing: 0.05em;">
          <i class="fa-solid fa-folder" style="font-size: 11px;" aria-hidden="true"></i>
          <%= folder.name %>
        </div>
        <% folder.documents.each do |doc| %>
          <%= link_to document_path(doc),
                      class: "d-flex align-items-center gap-2 px-2 py-1 rounded text-decoration-none small #{doc == current_document ? 'fw-semibold text-primary bg-primary bg-opacity-10' : 'text-body'}" do %>
            <i class="fa-solid fa-file-lines fa-xs text-muted" aria-hidden="true"></i>
            <span class="text-truncate"><%= doc.title %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <% if documents_without_folder.any? %>
      <div class="px-3 py-1 mt-1">
        <div class="text-muted fw-semibold text-uppercase mb-1"
             style="font-size: 11px; letter-spacing: 0.05em;">
          Sans dossier
        </div>
        <% documents_without_folder.each do |doc| %>
          <%= link_to document_path(doc),
                      class: "d-flex align-items-center gap-2 px-2 py-1 rounded text-decoration-none small #{doc == current_document ? 'fw-semibold text-primary bg-primary bg-opacity-10' : 'text-body'}" do %>
            <i class="fa-solid fa-file-lines fa-xs text-muted" aria-hidden="true"></i>
            <span class="text-truncate"><%= doc.title %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</aside>

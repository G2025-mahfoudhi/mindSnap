<% content_for :title, "Mes documents — MindSnap" %>
<main class="container py-4" aria-label="Mes documents">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-2">
      <%= link_to dashboard_path, class: "btn btn-outline-secondary btn-sm" do %>
        <i class="fa-solid fa-arrow-left me-1"></i>Dashboard
      <% end %>
      <h1 class="h3 mb-0">Mes documents</h1>
    </div>
    <%= link_to new_document_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-plus me-1" aria-hidden="true"></i> Nouveau document
    <% end %>
  </div>

  <% if @documents.empty? %>
    <div class="empty-state empty-state--card">
      <div class="empty-state__illustration">
        <%= image_tag "empty/documents.svg", alt: "" %>
      </div>
      <h3 class="empty-state__title">Aucun document pour le moment</h3>
      <p class="empty-state__text">Capture une note, colle un lien ou importe un fichier — l'IA s'occupe du reste.</p>
      <div class="empty-state__action">
        <%= link_to new_document_path, class: "btn btn-primary" do %>
          <i class="fa-solid fa-plus me-1" aria-hidden="true"></i> Ajouter un document
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="row g-3">
      <% @documents.each do |document| %>
        <div class="col-sm-6 col-lg-4">
          <%= render "shared/document_card", document: document, from: "documents", return_to: documents_path %>
        </div>
      <% end %>
    </div>
  <% end %>
</main>

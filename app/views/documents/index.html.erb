<% content_for :title, "Mes documents — MindSnap" %>
<main class="container py-4" aria-label="Mes documents">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-2">
      <%= link_to dashboard_path, class: "btn btn-outline-secondary btn-sm" do %>
        <i class="fa-solid fa-arrow-left me-1"></i>Dashboard
      <% end %>
      <h1 class="h3 mb-0">Mes documents</h1>
    </div>
    <%= link_to new_document_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-plus me-1" aria-hidden="true"></i> Nouveau document
    <% end %>
  </div>

  <% if @documents.empty? %>
    <div class="text-center py-5">
      <div class="icon-circle mx-auto mb-3" style="width: 64px; height: 64px; font-size: 1.75rem;">
        <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
      </div>
      <p class="text-muted mb-0">Aucun document pour le moment.</p>
    </div>
  <% else %>
    <div class="row g-3">
      <% @documents.each do |document| %>
        <div class="col-sm-6 col-lg-4">
          <%= render "shared/document_card", document: document, from: "documents" %>
        </div>
      <% end %>
    </div>
  <% end %>
</main>

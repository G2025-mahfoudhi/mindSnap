<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Mes documents</h1>
    <%= link_to "Nouveau document", new_document_path, class: "btn btn-primary" %>
  </div>

  <% if @documents.empty? %>
    <p class="text-muted">Aucun document pour le moment.</p>
  <% else %>
    <div class="row g-3">
      <% @documents.each do |document| %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100">
            <div class="card-body">
              <span class="badge bg-secondary mb-2"><%= document.document_type %></span>
              <h5 class="card-title"><%= document.title %></h5>
              <p class="card-text text-muted small"><%= truncate(document.content, length: 100) %></p>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
              <small class="text-muted"><%= document.date_injection&.strftime("%d/%m/%Y") %></small>
              <div class="d-flex gap-2">
                <%= link_to "Voir", document_path(document), class: "btn btn-sm btn-outline-primary" %>
                <%= link_to "Modifier", edit_document_path(document), class: "btn btn-sm btn-outline-secondary" %>
                <%= button_to "Supprimer", document_path(document),
                              method: :delete,
                              data: { turbo_confirm: "Supprimer ce document ?" },
                              class: "btn btn-sm btn-outline-danger" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
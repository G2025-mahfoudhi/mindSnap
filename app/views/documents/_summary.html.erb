<% suggest_doc_id      = document.folder_id.blank? ? document.id : 0 %>
<% folders_for_suggest  = local_assigns[:suggest_folders] || document.user.folders.includes(:parent).order(:name) %>
<% suggest_folders_json = folders_for_suggest.map { |f| { id: f.id, name: f.name } }.to_json %>
<% attachments_json = document.file.map { |a| { id: a.id, filename: a.blob.filename.to_s } }.to_json %>
<div class="doc-show-content"
     id="doc-summary"
     data-controller="folder-suggest"
     data-folder-suggest-document-id-value="<%= suggest_doc_id %>"
     data-folder-suggest-folders-value="<%= suggest_folders_json %>"
     data-folder-suggest-attachments-value="<%= attachments_json %>">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <p class="text-muted fw-semibold mb-0" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em;">
      <i class="fa-solid fa-robot me-1" aria-hidden="true"></i> Résumé IA
    </p>
    <% if document.content.present? || document.file.attached? %>
      <%= button_to summarize_document_path(document),
                    method: :post,
                    class: "btn btn-outline-secondary btn-sm",
                    aria: { label: "Régénérer le résumé de #{document.title}" } do %>
        <i class="fa-solid fa-rotate fa-xs" aria-hidden="true"></i>
        <span class="d-none d-md-inline ms-1">Régénérer</span>
      <% end %>
    <% end %>
  </div>
  <div id="doc-summary-content">
    <% if document.summary.present? %>
      <div class="markdown-content"><%= markdown document.summary %></div>
    <% elsif document.file.attached? || document.content.present? %>
      <p class="text-muted fst-italic mb-0">
        <i class="fa-solid fa-spinner fa-spin me-1" aria-hidden="true"></i>
        Génération du résumé en cours…
      </p>
    <% else %>
      <p class="text-muted fst-italic mb-0">Le résumé généré par l'IA apparaîtra ici.</p>
    <% end %>
  </div>
</div>

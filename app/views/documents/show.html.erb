<% content_for :title, "#{@document.title} — MindSnap" %>
<% content_for :body_class, "overflow-hidden" %>
<% content_for :main_style, "height: calc(100vh - 56px); overflow: hidden;" %>
<div class="d-flex" style="height: calc(100vh - 56px);">

  <div style="position: sticky; top: 0; height: 100%; width: 260px; min-width: 260px; overflow-y: auto; flex-shrink: 0;">
    <%= render "documents/sidebar",
               folders: @sidebar_folders,
               documents_without_folder: @documents_without_folder,
               current_document: @document %>
  </div>

  <main class="flex-grow-1 overflow-auto p-4">
    <div style="max-width: 760px; margin: 0 auto;">

      <%# ——— HEADER ——— %>
      <div class="doc-show-header">
        <div>
          <span class="doc-show-badge"><%= @document.document_type %></span>
          <h1 class="doc-show-title"><%= @document.title %></h1>
          <p class="doc-show-meta">
            Ajouté le <%= @document.date_injection&.strftime("%d/%m/%Y à %H:%M") %>
            <% if @document.folder %>
              &mdash;
              <%= link_to folder_path(@document.folder),
                          aria: { label: "Voir le dossier #{@document.folder.name}" } do %>
                <i class="fa-solid fa-folder fa-xs" aria-hidden="true"></i>
                <%= @document.folder.name %>
              <% end %>
            <% end %>
          </p>
          <% if @document.file.attached? %>
            <div class="d-flex flex-wrap gap-2 mt-2">
              <% @document.file.each do |attachment| %>
                <%= link_to download_document_path(@document, blob_signed_id: attachment.blob.signed_id),
                            class: "btn btn-outline-primary btn-sm",
                            data: { turbo: false },
                            aria: { label: "Télécharger #{attachment.filename}" } do %>
                  <i class="fa-solid fa-download fa-xs me-1" aria-hidden="true"></i>
                  <%= attachment.filename.to_s.truncate(25) %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="doc-show-actions">
          <%= link_to edit_document_path(@document),
                      class: "btn btn-outline-primary btn-sm",
                      aria: { label: "Modifier #{@document.title}" } do %>
            <i class="fa-solid fa-pen" aria-hidden="true"></i>
          <% end %>
          <%= button_to document_path(@document),
                        method: :delete,
                        data: { turbo_confirm: "Supprimer ce document ?" },
                        class: "btn btn-outline-danger btn-sm",
                        form: { aria: { label: "Supprimer #{@document.title}" } } do %>
            <i class="fa-solid fa-trash" aria-hidden="true"></i>
          <% end %>
        </div>
      </div>

      <%# ——— TAGS IA ——— %>
      <% if @document.tags.any? %>
        <div class="d-flex flex-wrap gap-1 mt-3 mb-4">
          <% @document.tags.each do |tag| %>
            <span class="badge bg-primary bg-opacity-10 text-primary"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>

      <%# ——— RÉSUMÉ IA ——— %>
      <%= render "documents/summary", document: @document %>


      <%# ——— CONTENU ——— %>
      <% if @document.file.attached? || @document.content.present? %>
        <div class="mb-4 pt-4">
          <button class="btn btn-outline-secondary btn-sm"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#doc-content"
                  aria-expanded="false"
                  aria-controls="doc-content">
            Voir le document
          </button>
          <div class="collapse mt-3" id="doc-content">
            <% if @document.file.attached? %>
              <% @document.file.each do |attachment| %>
                <% if attachment.content_type == "application/pdf" %>
                  <iframe data-src="<%= document_inline_url(attachment) %>"
                          src="about:blank"
                          width="100%"
                          height="800px"
                          style="border: 1px solid #ebebeb; border-radius: 8px;"
                          title="<%= attachment.filename %>">
                  </iframe>
                <% elsif attachment.content_type.start_with?("image/") %>
                  <%= image_tag document_inline_url(attachment), style: "max-width: 100%; border-radius: 8px;", alt: attachment.filename %>
                <% else %>
                  <div class="doc-show-content">
                    <pre style="white-space: pre-wrap; word-break: break-word; font-family: inherit; margin: 0;"><%= @document.content %></pre>
                  </div>
                <% end %>
              <% end %>
            <% elsif @document.content.present? %>
              <div class="doc-show-content">
                <pre style="white-space: pre-wrap; word-break: break-word; font-family: inherit; margin: 0;"><%= @document.content %></pre>
              </div>
            <% end %>
          </div>
          <script>
            document.getElementById('doc-content').addEventListener('show.bs.collapse', function() {
              this.querySelectorAll('iframe[data-src]').forEach(function(iframe) {
                if (iframe.src === 'about:blank') iframe.src = iframe.dataset.src;
              });
            });
          </script>
        </div>
      <% end %>


    </div>
  </main>

</div>

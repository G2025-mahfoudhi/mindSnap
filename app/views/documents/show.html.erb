<div class="container py-4" style="max-width: 800px;">
  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <span class="badge bg-secondary mb-2"><%= @document.document_type %></span>
      <h1 class="h3 mb-0"><%= @document.title %></h1>
      <small class="text-muted">
        Ajouté le <%= @document.date_injection&.strftime("%d/%m/%Y à %H:%M") %>
        <% if @document.folder %>
          &mdash; Dossier : <%= @document.folder.name %>
        <% end %>
      </small>
    </div>
    <div class="d-flex gap-2">
      <%= link_to "Modifier", edit_document_path(@document), class: "btn btn-outline-secondary btn-sm" %>
      <%= button_to "Supprimer", document_path(@document),
                    method: :delete,
                    data: { turbo_confirm: "Supprimer ce document ?" },
                    class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <%= simple_format @document.content %>
    </div>
  </div>

  <% if @document.file.attached? %>
    <div class="card mt-3">
      <div class="card-body">
        <h6 class="card-title mb-3">Fichiers joints</h6>
        <ul class="list-unstyled mb-0">
          <% @document.file.each do |attachment| %>
            <li class="d-flex align-items-center gap-2 mb-2">
              <span>📎</span>
              <span class="text-muted small flex-grow-1"><%= attachment.filename %></span>
              <%= link_to "Télécharger", rails_blob_path(attachment, disposition: "attachment"),
                          class: "btn btn-outline-primary btn-sm" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%= link_to "← Retour aux documents", documents_path, class: "btn btn-link mt-3 ps-0" %>
</div>
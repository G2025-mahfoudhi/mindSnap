<% content_for :title, "#{@document.title} — MindSnap" %>
<div class="d-flex" style="min-height: calc(100vh - 56px);">

  <%= render "documents/sidebar",
             folders: @folders,
             documents_without_folder: @documents_without_folder,
             current_document: @document %>

  <main class="flex-grow-1 overflow-auto p-4">
    <div style="max-width: 760px; margin: 0 auto;">

      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <span class="badge bg-primary bg-opacity-10 text-primary mb-2"><%= @document.document_type %></span>
          <h1 class="h3 mb-0"><%= @document.title %></h1>
          <small class="text-muted">
            Ajouté le <%= @document.date_injection&.strftime("%d/%m/%Y à %H:%M") %>
            <% if @document.folder %>
              &mdash;
              <%= link_to folder_path(@document.folder),
                          class: "text-decoration-none text-muted",
                          aria: { label: "Voir le dossier #{@document.folder.name}" } do %>
                <i class="fa-solid fa-folder fa-xs" aria-hidden="true"></i>
                <%= @document.folder.name %>
              <% end %>
            <% end %>
          </small>
        </div>
        <div class="d-flex gap-2">
          <%= link_to edit_document_path(@document),
                      class: "btn btn-outline-primary btn-sm",
                      aria: { label: "Modifier #{@document.title}" } do %>
            <i class="fa-solid fa-pen" aria-hidden="true"></i>
          <% end %>
          <%= button_to document_path(@document),
                        method: :delete,
                        data: { turbo_confirm: "Supprimer ce document ?" },
                        class: "btn btn-outline-danger btn-sm",
                        form: { aria: { label: "Supprimer #{@document.title}" } } do %>
            <i class="fa-solid fa-trash" aria-hidden="true"></i>
          <% end %>
        </div>
      </div>

      <% if @document.file.attached? %>
        <div class="mb-3">
          <% @document.file.each do |attachment| %>
            <span class="badge bg-light text-dark border me-1">
              <i class="fa-solid fa-paperclip fa-xs" aria-hidden="true"></i>
              <%= attachment.filename %>
            </span>
          <% end %>
        </div>
      <% end %>

      <div class="card border-0" style="box-shadow: 0 4px 24px rgba(0,0,0,.06);">
        <div class="card-body">
          <%= simple_format @document.content %>
        </div>
      </div>

    </div>
  </main>

</div>

<div class="container py-4" style="max-width: 800px;">
  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <span class="badge bg-secondary mb-2"><%= @document.document_type %></span>
      <h1 class="h3 mb-0"><%= @document.title %></h1>
      <small class="text-muted">
        Ajouté le <%= @document.date_injection&.strftime("%d/%m/%Y à %H:%M") %>
        <% if @document.folder %>
          &mdash; Dossier : <%= @document.folder.name %>
        <% end %>
      </small>
    </div>
    <div class="d-flex gap-2">
      <%= link_to "Modifier", edit_document_path(@document), class: "btn btn-outline-secondary btn-sm" %>
      <%= button_to "Supprimer", document_path(@document),
                    method: :delete,
                    data: { turbo_confirm: "Supprimer ce document ?" },
                    class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <%= simple_format @document.content %>
    </div>
  </div>

  <%= link_to "← Retour aux documents", documents_path, class: "btn btn-link mt-3 ps-0" %>
</div>
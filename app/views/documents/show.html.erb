<% content_for :title, "#{@document.title} — MindSnap" %>
<% content_for :body_class, "overflow-hidden" %>
<% content_for :main_style, "height: calc(100vh - var(--navbar-height, 56px) - var(--footer-height, 60px)); overflow: hidden;" %>

<%= turbo_stream_from @doc_chat_conversation %>
<%= turbo_stream_from @document %>

<div class="offcanvas offcanvas-end"
     id="doc-chat-panel"
     tabindex="-1"
     aria-labelledby="doc-chat-panel-label"
     data-controller="doc-chat"
     data-doc-chat-url-value="<%= chat_document_path(@document) %>"
     style="width: min(420px, 100vw);">
  <div class="offcanvas-header border-bottom py-3">
    <h6 class="offcanvas-title fw-semibold mb-0 me-3" id="doc-chat-panel-label">
      <i class="fa-solid fa-comments me-2 text-primary" aria-hidden="true"></i>Discuter avec l'IA
    </h6>
    <%= button_to reset_chat_document_path(@document),
                  method: :delete,
                  class: "btn btn-outline-danger btn-sm d-flex align-items-center",
                  form: { data: { turbo_confirm: "Supprimer tout l'historique de cette discussion ?" } },
                  aria: { label: "Réinitialiser la discussion" } do %>
      <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
      <span class="d-none d-sm-inline ms-1">Réinitialiser</span>
    <% end %>
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
  </div>
  <div class="offcanvas-body p-0 d-flex flex-column" style="min-height: 0;">
    <%= turbo_frame_tag "doc-chat-frame",
                        data: { "doc-chat-target": "frame" },
                        class: "d-flex flex-column flex-grow-1",
                        style: "min-height: 0;" do %>
      <div class="d-flex justify-content-center align-items-center flex-grow-1">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Chargement...</span>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="d-flex" style="height: calc(100vh - var(--navbar-height, 56px) - var(--footer-height, 60px));">

  <%= render "documents/sidebar",
             folders: @sidebar_folders,
             documents_without_folder: @documents_without_folder,
             current_document: @document %>

  <main class="flex-grow-1 overflow-auto p-4" style="padding-bottom: var(--footer-height, 5rem) !important;">
    <div style="max-width: 760px; margin: 0 auto;">

      <%# ——— BOUTON RETOUR ——— %>
      <% if params[:from] == "dashboard" %>
        <%= link_to dashboard_path,
                    class: "d-inline-flex align-items-center gap-2 text-decoration-none small mb-3",
                    style: "color: #5a6370;" do %>
          <i class="fa-solid fa-arrow-left fa-xs" aria-hidden="true"></i>
          Dashboard
        <% end %>
      <% elsif params[:from] == "documents" %>
        <%= link_to documents_path,
                    class: "d-inline-flex align-items-center gap-2 text-decoration-none small mb-3",
                    style: "color: #5a6370;",
                    aria: { label: "Retour à Mes documents" } do %>
          <i class="fa-solid fa-arrow-left fa-xs" aria-hidden="true"></i>
          Mes documents
        <% end %>
      <% elsif params[:from] == "espace" && @document.folder %>
        <%= link_to folder_path(@document.folder),
                    class: "d-inline-flex align-items-center gap-2 text-decoration-none small mb-3",
                    style: "color: #5a6370;",
                    aria: { label: "Retour au dossier #{@document.folder.name}" } do %>
          <i class="fa-solid fa-arrow-left fa-xs" aria-hidden="true"></i>
          Retour au dossier
        <% end %>
      <% else %>
        <%= link_to espaces_path,
                    class: "d-inline-flex align-items-center gap-2 text-decoration-none small mb-3",
                    style: "color: #5a6370;",
                    aria: { label: "Retour à Mon espace" } do %>
          <i class="fa-solid fa-arrow-left fa-xs" aria-hidden="true"></i>
          Mon espace
        <% end %>
      <% end %>

      <%# ——— HEADER ——— %>
      <div class="doc-show-header">
        <div>
          <span class="doc-show-badge"><%= @document.document_type %></span>
          <h1 class="doc-show-title"><%= @document.title %></h1>
          <p class="doc-show-meta">
            Ajouté le <%= local_time(@document.date_injection, :datetime) %>
            <% if @document.folder %>
              &mdash;
              <%= link_to folder_path(@document.folder),
                          aria: { label: "Voir le dossier #{@document.folder.name}" } do %>
                <i class="fa-solid fa-folder fa-xs" aria-hidden="true"></i>
                <%= @document.folder.name %>
              <% end %>
            <% end %>
          </p>
          <% if @document.file.attached? %>
            <div class="d-flex flex-wrap gap-2 mt-2">
              <% @document.file.each do |attachment| %>
                <%= link_to download_document_path(@document, blob_signed_id: attachment.blob.signed_id),
                            class: "btn btn-outline-primary btn-sm",
                            data: { turbo: false },
                            aria: { label: "Télécharger #{attachment.filename}" } do %>
                  <i class="fa-solid fa-download fa-xs me-1" aria-hidden="true"></i>
                  <%= attachment.filename.to_s.truncate(25) %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% show_return_to = document_path(@document, from: params[:from]) %>
        <% delete_return_to = case params[:from]
                              when "documents" then documents_path
                              when "dashboard" then dashboard_path
                              else @document.folder ? folder_path(@document.folder) : espaces_path
                              end %>
        <div class="doc-show-actions">
          <button type="button"
                  class="btn btn-primary btn-sm"
                  data-bs-toggle="offcanvas"
                  data-bs-target="#doc-chat-panel"
                  aria-controls="doc-chat-panel">
            <i class="fa-solid fa-comments me-1" aria-hidden="true"></i> Discuter
          </button>
          <%= link_to edit_document_path(@document, return_to: show_return_to),
                      class: "btn btn-outline-primary btn-sm",
                      aria: { label: "Modifier #{@document.title}" } do %>
            <i class="fa-solid fa-pen" aria-hidden="true"></i>
          <% end %>
          <%= button_to document_path(@document),
                        method: :delete,
                        params: { return_to: delete_return_to },
                        data: { turbo_confirm: "Supprimer ce document ?" },
                        class: "btn btn-outline-danger btn-sm",
                        form: { aria: { label: "Supprimer #{@document.title}" } } do %>
            <i class="fa-solid fa-trash" aria-hidden="true"></i>
          <% end %>
        </div>
      </div>

      <%# ——— TAGS IA ——— %>
      <% if @document.tags.any? %>
        <div class="d-flex flex-wrap gap-1 mt-3 mb-4">
          <% @document.tags.each do |tag| %>
            <span class="badge bg-primary bg-opacity-10 text-primary"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>

      <%# ——— RÉSUMÉ IA ——— %>
      <%= render "documents/summary", document: @document, suggest_folders: @suggest_folders %>


      <%# ——— CONTENU ——— %>
      <% doc_ready = @document.file.attached? || @document.content.present? %>
        <div id="doc-content-section" class="mb-4 pt-4<%= ' d-none' unless doc_ready %>">
          <% file_count = @document.file.count %>
          <button id="doc-toggle-btn"
                  class="btn btn-outline-secondary btn-sm"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#doc-content"
                  aria-expanded="false"
                  aria-controls="doc-content"
                  data-label-show="<%= file_count > 1 ? "Voir les documents (#{file_count})" : "Voir le document" %>"
                  data-label-hide="<%= file_count > 1 ? 'Fermer les documents' : 'Fermer le document' %>">
            <%= file_count > 1 ? "Voir les documents (#{file_count})" : "Voir le document" %>
          </button>
          <div class="collapse mt-3" id="doc-content">
            <% if @document.file.attached? %>
              <% @document.file.each do |attachment| %>
                <% if attachment.content_type == "application/pdf" %>
                  <iframe data-src="<%= document_inline_url(attachment) %>"
                          src="about:blank"
                          width="100%"
                          class="pdf-iframe" style="height: clamp(300px, 60vh, 800px);"
                          style="border: 1px solid #ebebeb; border-radius: 8px;"
                          title="<%= attachment.filename %>">
                  </iframe>
                <% elsif attachment.content_type.start_with?("image/") %>
                  <%= image_tag document_inline_url(attachment), style: "max-width: 100%; border-radius: 8px;", alt: attachment.filename %>
                <% else %>
                  <div class="doc-show-content markdown-content">
                    <%= markdown(@document.content) %>
                  </div>
                <% end %>
              <% end %>
            <% elsif @document.content.present? %>
              <div class="doc-show-content markdown-content">
                <%= markdown(@document.content) %>
              </div>
            <% end %>
          </div>
          <script nonce="<%= request.content_security_policy_nonce %>">
            (function() {
              var el  = document.getElementById('doc-content');
              var btn = document.getElementById('doc-toggle-btn');
              el.addEventListener('show.bs.collapse', function() {
                this.querySelectorAll('iframe[data-src]').forEach(function(iframe) {
                  if (iframe.src === 'about:blank') iframe.src = iframe.dataset.src;
                });
                btn.textContent = btn.dataset.labelHide;
              });
              el.addEventListener('hide.bs.collapse', function() {
                btn.textContent = btn.dataset.labelShow;
              });
            })();
          </script>
        </div>


    </div>
  </main>

</div>

<%# folder, all_folders, depth, current_document %>
<% doc_pad  = "#{0.5 + depth * 1.0}rem" %>
<% child_pad = "#{0.5 + (depth + 1) * 1.0}rem" %>

<%# — Nom du dossier — %>
<%= link_to folder_path(folder),
            class: "d-flex align-items-center gap-2 py-1 rounded text-decoration-none small #{depth == 0 ? 'fw-semibold text-uppercase' : 'sidebar-doc-item'}",
            style: "padding-left: #{doc_pad}; padding-right: 0.5rem; #{ depth == 0 ? 'font-size: 11px; letter-spacing: 0.05em; color: #2A4B4B;' : '' }" do %>
  <i class="fa-solid fa-folder fa-xs" style="color: #f0ad4e; flex-shrink: 0;" aria-hidden="true"></i>
  <span class="text-truncate"><%= folder.name %></span>
<% end %>

<%# — Documents du dossier — %>
<% folder.documents.each do |doc| %>
  <%= link_to document_path(doc),
              class: "d-flex align-items-center gap-2 py-1 rounded text-decoration-none small #{doc == current_document ? 'fw-semibold sidebar-doc-active' : 'sidebar-doc-item'}",
              style: "padding-left: #{child_pad}; padding-right: 0.5rem;" do %>
    <i class="fa-solid fa-file-lines fa-xs" style="color: #3d7f7e; flex-shrink: 0;" aria-hidden="true"></i>
    <span class="text-truncate"><%= doc.title %></span>
  <% end %>
<% end %>

<%# — Sous-dossiers (récursif) — %>
<% all_folders.select { |f| f.parent_id == folder.id }.each do |child| %>
  <%= render "documents/folder_node",
             folder: child,
             all_folders: all_folders,
             depth: depth + 1,
             current_document: current_document %>
<% end %>

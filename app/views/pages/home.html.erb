<%# --- Hero --- %>
<section class="hero" aria-labelledby="hero-title" data-controller="hero-video">
  <div class="hero__video-wrapper" aria-hidden="true" data-hero-video-target="wrapper">
    <video src="<%= asset_path 'hero/hero-bg.mp4' %>"
           autoplay muted playsinline preload="auto"
           poster="<%= asset_path 'hero-illustration.svg' %>"
           class="hero__video hero__video--visible"
           data-hero-video-target="videoA"></video>
    <video src="<%= asset_path 'hero/hero-bg.mp4' %>"
           muted playsinline preload="auto"
           poster="<%= asset_path 'hero-illustration.svg' %>"
           class="hero__video hero__video--hidden"
           data-hero-video-target="videoB"></video>
    <div class="hero__overlay"></div>
  </div>
  <div class="container hero__content">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <div class="hero__text-card">
          <h1 class="hero__title" id="hero-title">MindSnap</h1>
          <p class="hero__tagline">Ton deuxième cerveau</p>
          <p class="hero__subtitle">
            Capture tes idées, tes cours, tes documents. Retrouve-les instantanément grâce à l'IA.
          </p>
          <div class="hero__actions">
            <% if user_signed_in? %>
              <%= link_to "Dashboard", dashboard_path, class: "btn btn-primary btn-lg px-4" %>
            <% else %>
              <%= link_to "Commencer", new_user_registration_path, class: "btn btn-primary btn-lg px-4" %>
            <% end %>
            <%= link_to "En savoir plus", "#features", class: "btn btn-outline-secondary btn-lg px-4" %>
          </div>
        </div>
      </div>
      <%# <div class="col-lg-6 d-none d-lg-block">
        <div class="hero__illustration">
          <%= image_tag "hero-illustration.svg", alt: "Illustration MindSnap — capture et organise tes documents", class: "img-fluid" %>
        </div>
      </div> %>
    </div>
  </div>
</section>

<%# --- Features --- %>
<section class="features" id="features" aria-labelledby="features-title">
  <div class="container">
    <header class="features__header">
      <h2 class="features__title" id="features-title">Comment ça marche</h2>
      <p class="features__subtitle">Un espace unique pour capturer, organiser et retrouver l'ensemble de tes connaissances.</p>
    </header>

    <div class="row g-4">
      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-camera"></i>
          </div>
          <h3 class="feature-card__title">Capture tes documents</h3>
          <p class="feature-card__text">Prends une photo, l'OCR fait le reste. Numérise n'importe quel document en quelques secondes.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-cloud-arrow-up"></i>
          </div>
          <h3 class="feature-card__title">Stockage cloud sécurisé</h3>
          <p class="feature-card__text">Accessible partout, tout le temps. Tes documents sont chiffrés et sauvegardés automatiquement.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-folder-tree"></i>
          </div>
          <h3 class="feature-card__title">Organisation intuitive</h3>
          <p class="feature-card__text">Classe par dossiers, matières, projets. Une arborescence flexible qui s'adapte à ta logique.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <h3 class="feature-card__title">Recherche intelligente</h3>
          <p class="feature-card__text">Trouve n'importe quel document en une seconde. Même dans le texte des images grâce à l'OCR.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-file-export"></i>
          </div>
          <h3 class="feature-card__title">Export facile</h3>
          <p class="feature-card__text">PDF, Word, texte — partage tes documents comme tu veux, avec qui tu veux.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-robot"></i>
          </div>
          <h3 class="feature-card__title">Pose des questions à tes docs</h3>
          <p class="feature-card__text">L'IA comprend le contenu de tes documents et répond à tes questions en langage naturel.</p>
        </article>
      </div>
    </div>
  </div>
</section>

<%# --- How it works --- %>
<section class="how-it-works" id="how-it-works" aria-labelledby="how-title">
  <div class="container">
    <header class="how-it-works__header">
      <h2 class="how-it-works__title" id="how-title">Tout ce dont tu as besoin</h2>
      <p class="how-it-works__subtitle">Quatre étapes simples pour transformer ta manière de travailler.</p>
    </header>

    <div class="row steps-row">
      <div class="col-md-3">
        <div class="step">
          <span class="step__number" aria-hidden="true">1</span>
          <div class="step__illustration">
            <%= image_tag "step-capture.svg", alt: "", class: "img-fluid" %>
          </div>
          <h3 class="step__title">Capture</h3>
          <p class="step__text">Prends en photo ou importe ton document. L'OCR analyse le texte automatiquement.</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="step">
          <span class="step__number" aria-hidden="true">2</span>
          <div class="step__illustration">
            <%= image_tag "step-store.svg", alt: "", class: "img-fluid" %>
          </div>
          <h3 class="step__title">Stocke</h3>
          <p class="step__text">Tes documents sont sauvegardés dans le cloud, accessibles partout et en toute sécurité.</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="step">
          <span class="step__number" aria-hidden="true">3</span>
          <div class="step__illustration">
            <%= image_tag "step-organize.svg", alt: "", class: "img-fluid" %>
          </div>
          <h3 class="step__title">Organise</h3>
          <p class="step__text">Range dans le bon dossier automatiquement. Ou laisse l'IA te proposer le meilleur classement.</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="step">
          <span class="step__number" aria-hidden="true">4</span>
          <div class="step__illustration">
            <%= image_tag "step-find.svg", alt: "", class: "img-fluid" %>
          </div>
          <h3 class="step__title">Retrouve</h3>
          <p class="step__text">L'IA indexe tout. Une recherche et tu retrouves n'importe quel document en une seconde.</p>
        </div>
      </div>
    </div>
  </div>
</section>

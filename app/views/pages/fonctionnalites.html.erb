<% content_for :title, "Fonctionnalités — MindSnap" %>

<%# ——— Hero ——— %>
<section class="equipe-hero">
  <div class="equipe-hero__banner" aria-hidden="true">
    <%= image_tag "pages/about-hero.svg", alt: "" %>
  </div>
  <div class="container text-center">
    <h1 class="equipe-hero__title">Fonctionnalités</h1>
    <p class="mt-3" style="font-size: 1.1rem; color: rgba(0,0,0,.55); max-width: 520px; margin: 0 auto;">
      Tout ce que MindSnap fait pour transformer ta façon de capturer et retrouver tes connaissances.
    </p>
  </div>
</section>

<%# ——— Gestion & Organisation ——— %>
<section class="features">
  <div class="container">
    <header class="features__header">
      <h2 class="features__title">Gestion & Organisation</h2>
      <p class="features__subtitle">Importe, structure et retrouve tous tes documents en un seul endroit.</p>
    </header>

    <div class="row g-4">
      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-file-lines"></i>
          </div>
          <h3 class="feature-card__title">Multi-formats</h3>
          <p class="feature-card__text">PDF, Word, images, notes texte, liens web — MindSnap accepte tous les formats et les unifie dans ta base de connaissances.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-folder-tree"></i>
          </div>
          <h3 class="feature-card__title">Dossiers & sous-dossiers</h3>
          <p class="feature-card__text">Crée une arborescence de dossiers qui colle à ta logique — par matière, projet ou thème. Déplace tes documents en glisser-déposer.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-cloud-arrow-up"></i>
          </div>
          <h3 class="feature-card__title">Stockage cloud</h3>
          <p class="feature-card__text">Tous tes fichiers sont sauvegardés dans le cloud. Accessibles depuis n'importe quel appareil, à tout moment.</p>
        </article>
      </div>
    </div>
  </div>
</section>

<%# ——— IA ——— %>
<section class="features" style="background: #fff;">
  <div class="container">
    <header class="features__header">
      <h2 class="features__title">Intelligence Artificielle</h2>
      <p class="features__subtitle">L'IA travaille pour toi — résumés, tags, conversations et recherche sémantique.</p>
    </header>

    <div class="row g-4">
      <div class="col-md-6 col-lg-4">
        <article class="feature-card" style="background: #f8f9fa;">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-file-contract"></i>
          </div>
          <h3 class="feature-card__title">Résumés automatiques</h3>
          <p class="feature-card__text">À chaque nouveau document, l'IA génère un résumé concis. L'essentiel est là sans avoir à relire un long fichier.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card" style="background: #f8f9fa;">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-tags"></i>
          </div>
          <h3 class="feature-card__title">Tags IA</h3>
          <p class="feature-card__text">L'IA attribue automatiquement des tags pertinents à chaque document. Retrouve tes docs par thème sans avoir à les classer manuellement.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card" style="background: #f8f9fa;">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <h3 class="feature-card__title">Recherche sémantique</h3>
          <p class="feature-card__text">La recherche comprend le sens de ta requête. Cherche "contrat location" et retrouve aussi les docs qui parlent de "bail" ou "logement".</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card" style="background: #f8f9fa;">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-comments"></i>
          </div>
          <h3 class="feature-card__title">Conversations IA</h3>
          <p class="feature-card__text">Pose des questions à l'IA sur un document précis ou lance une conversation générale. L'IA connaît tes docs et répond en langage naturel.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card" style="background: #f8f9fa;">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-wand-magic-sparkles"></i>
          </div>
          <h3 class="feature-card__title">Extraction de texte</h3>
          <p class="feature-card__text">OCR pour les images, parsing pour les PDF et Word. Le contenu est extrait automatiquement et rendu exploitable par l'IA.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card" style="background: #f8f9fa;">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-globe"></i>
          </div>
          <h3 class="feature-card__title">Capture de pages web</h3>
          <p class="feature-card__text">Colle une URL et MindSnap extrait automatiquement le contenu. Articles, docs en ligne — tout intègre ta base de connaissances.</p>
        </article>
      </div>
    </div>
  </div>
</section>

<%# ——— Expérience ——— %>
<section class="features">
  <div class="container">
    <header class="features__header">
      <h2 class="features__title">Expérience utilisateur</h2>
      <p class="features__subtitle">Conçu pour être rapide, fluide et agréable à utiliser au quotidien.</p>
    </header>

    <div class="row g-4 justify-content-center">
      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-microphone"></i>
          </div>
          <h3 class="feature-card__title">Dictée vocale</h3>
          <p class="feature-card__text">Dicte tes notes à la voix. L'IA transcrit ta parole en texte en temps réel. Pratique pour capturer une idée rapidement.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-volume-high"></i>
          </div>
          <h3 class="feature-card__title">Synthèse vocale</h3>
          <p class="feature-card__text">L'IA peut lire ses réponses à voix haute. Écoute tes résumés ou les réponses du chat sans lire l'écran.</p>
        </article>
      </div>

      <div class="col-md-6 col-lg-4">
        <article class="feature-card">
          <div class="feature-card__icon" aria-hidden="true">
            <i class="fa-solid fa-gauge-high"></i>
          </div>
          <h3 class="feature-card__title">Dashboard</h3>
          <p class="feature-card__text">Un tableau de bord clair pour voir tes documents récents, tes stats et accéder rapidement à tout ce dont tu as besoin.</p>
        </article>
      </div>
    </div>
  </div>
</section>

<% unless user_signed_in? %>
<%# ——— CTA ——— %>
<section class="py-5 text-center" style="background: linear-gradient(135deg, #f0f4ff 0%, #e8f5e9 100%);">
  <div class="container">
    <h2 class="h3 fw-bold mb-3">Prêt à essayer ?</h2>
    <p class="text-muted mb-4">Crée ton compte gratuitement et commence dès aujourd'hui.</p>
    <%= link_to "Commencer gratuitement", new_user_registration_path, class: "btn btn-primary btn-lg px-5" %>
  </div>
</section>
<% end %>

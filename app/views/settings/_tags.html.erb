<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h5 class="card-title mb-4">Mes tags</h5>

        <% if tags.empty? %>
          <div class="text-center py-4 text-muted">
            <i class="fa-solid fa-tags fa-2x mb-3 d-block"></i>
            <p>Aucun tag pour l'instant.</p>
            <p class="small">Ajoute des documents et l'IA générera des tags automatiquement.</p>
          </div>
        <% else %>
          <p class="text-muted small mb-3">
            <%= tags.size %> tag(s). Clique sur un tag pour le renommer. Utilise la sélection pour exporter par tags.
          </p>

          <div class="list-group list-group-flush" id="tags_list">
            <%= render partial: "tag_row", collection: tags, as: :tag %>
          </div>

          <div class="mt-4 pt-3 border-top">
            <div class="d-flex align-items-center gap-2">
              <button class="btn btn-outline-primary btn-sm"
                      data-action="click->settings-tabs#toggleTagSelection">
                <span data-settings-tabs-target="selectAllLabel">Tout sélectionner</span>
              </button>
              <span class="text-muted small" data-settings-tabs-target="selectionCount">0 tag(s) sélectionné(s)</span>
            </div>

            <div class="mt-3 d-flex gap-2">
              <%= button_tag "Exporter en JSON",
                    type: "button",
                    class: "btn btn-primary btn-sm",
                    data: {
                      bs_toggle: "tooltip",
                      bs_title: "Format idéal pour donner à une IA",
                      action: "click->settings-tabs#exportByTags",
                      settings_tabs_format_param: "json"
                    } %>
              <%= button_tag "Exporter en Markdown",
                    type: "button",
                    class: "btn btn-outline-primary btn-sm",
                    data: {
                      bs_toggle: "tooltip",
                      bs_title: "Format idéal pour lire",
                      action: "click->settings-tabs#exportByTags",
                      settings_tabs_format_param: "markdown"
                    } %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

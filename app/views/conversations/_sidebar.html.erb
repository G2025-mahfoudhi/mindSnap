<aside class="d-flex flex-column sidebar-collapsible"
       aria-label="Panneau de conversations"
       style="width: 260px; min-width: 260px; background-color: #2A4B4B; overflow: hidden;">

  <div class="sidebar-toggle-handle p-3 border-bottom border-white border-opacity-25 d-flex align-items-center gap-2"
       style="flex-shrink: 0;">
    <div class="sidebar-toggle-content flex-grow-1" style="min-width: 0;">
      <%= button_to conversations_path,
                    method: :post,
                    class: "btn w-100 d-flex align-items-center justify-content-center gap-2 fw-medium text-white btn-primary",
                    aria: { label: "Créer une nouvelle conversation" } do %>
        <i class="fa-solid fa-plus" aria-hidden="true"></i>
        <span style="white-space: nowrap;">Nouvelle conversation</span>
      <% end %>
    </div>
    <button type="button"
            class="btn btn-sm btn-link p-0 flex-shrink-0"
            data-action="sidebar-toggle#toggle"
            aria-pressed="false"
            title="Réduire / agrandir le panneau"
            style="color: rgba(255,255,255,0.5);">
      <i class="fa-solid fa-chevron-left" aria-hidden="true" data-sidebar-toggle-icon></i>
    </button>
  </div>

  <h2 id="sidebar-conversations-heading"
      class="px-3 pt-3 pb-1 mb-0 text-uppercase text-white-50"
      style="font-size: 11px; letter-spacing: 0.06em;">
    Mes conversations
  </h2>

  <nav aria-labelledby="sidebar-conversations-heading" class="flex-grow-1 overflow-auto px-2 pb-3">
    <ul id="chatList" class="list-unstyled mb-0">
      <% conversations.each do |conversation| %>
        <% active = conversation == current_conversation %>
        <li class="d-flex align-items-center gap-2 px-2 py-2 rounded mb-1 chat-link <%= 'active-conversation' if active %>">
          <%= link_to conversation_path(conversation),
                      class: "d-flex align-items-center gap-2 flex-grow-1 text-decoration-none text-white",
                      style: "min-width: 0;",
                      aria: { current: active ? "page" : nil } do %>
            <i class="fa-solid fa-comment text-white-50" aria-hidden="true"></i>
            <span class="text-truncate small" id="chat-title-<%= conversation.id %>">
              <%= conversation.name %>
            </span>
          <% end %>

          <div class="chat-actions d-flex gap-1" role="group" aria-label="Actions pour <%= conversation.name %>">
            <%= button_to conversation_path(conversation),
                          method: :delete,
                          class: "btn btn-sm p-0 px-1 text-white-50",
                          form_class: "d-inline",
                          data: { turbo_confirm: "Supprimer cette conversation ?" },
                          aria: { label: "Supprimer #{conversation.name}" } do %>
              <i class="fa-solid fa-trash" style="font-size: 12px;" aria-hidden="true"></i>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  </nav>

  <div class="py-2 px-3 border-top border-white border-opacity-25 d-flex align-items-center justify-content-center gap-2 bg-primary"
       aria-label="Compte de <%= current_user.first_name %> <%= current_user.last_name %>">
    <span role="img"
          aria-label="Avatar de <%= current_user.first_name %> <%= current_user.last_name %>"
          class="rounded-circle d-flex align-items-center justify-content-center text-white fw-semibold flex-shrink-0"
          style="width: 36px; height: 36px; background: rgba(255,255,255,0.2); font-size: 13px;">
      <%= current_user.first_name&.first&.upcase || "?" %><%= current_user.last_name&.first&.upcase %>
    </span>
    <div style="min-width: 0;">
      <div class="text-white small fw-semibold text-truncate">
        <%= current_user.first_name.presence || current_user.email %>
        <%= current_user.last_name %>
      </div>
    </div>
  </div>
</aside>


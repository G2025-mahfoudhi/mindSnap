<% content_for :title, "Conversations — MindSnap" %>

<div class="d-flex" style="height: calc(var(--vh, 100vh) - var(--navbar-height, 56px) - var(--footer-height, 60px));" role="main" aria-label="Conversations">
  <%= render "conversations/sidebar",
             conversations: @conversations,
             current_conversation: nil %>

  <div class="d-flex flex-column flex-grow-1 align-items-center justify-content-center bg-light">
    <div class="empty-state empty-state--card">
      <div class="empty-state__illustration">
        <%= image_tag "empty/conversations.svg", alt: "" %>
      </div>
      <h3 class="empty-state__title">Tes conversations IA</h3>
      <p class="empty-state__text">
        Sélectionne une conversation dans la liste ou crée-en une nouvelle pour poser des questions sur tes documents.
      </p>
      <div class="empty-state__action">
        <%= button_to conversations_path,
                      method: :post,
                      class: "btn btn-primary",
                      aria: { label: "Créer une nouvelle conversation" } do %>
          <i class="fa-solid fa-plus me-1" aria-hidden="true"></i>
          Nouvelle conversation
        <% end %>
      </div>
    </div>
  </div>
</div>

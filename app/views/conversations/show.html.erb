<% content_for :title, "#{@conversation.name} — MindSnap" %>

<%= turbo_stream_from @conversation %>

<div class="d-flex" style="height: calc(var(--vh, 100vh) - var(--navbar-height, 56px) - var(--footer-height, 60px));" role="main" aria-label="<%= @conversation.name %>">
  <%= render "conversations/sidebar", conversations: @conversations, current_conversation: @conversation %>

  <div class="d-flex flex-column flex-grow-1 overflow-hidden"
       data-controller="voice"
       data-voice-auto-submit-value="true">
    <% suggest_doc_id = @suggest_document&.folder_id.blank? ? @suggest_document&.id.to_i : 0 %>
    <% suggest_folders_json = (@suggest_folders || []).map { |f| { id: f.id, name: f.name } }.to_json %>
    <div id="messages"
         class="flex-grow-1 overflow-auto p-4"
         data-controller="chat-scroll folder-suggest"
         data-folder-suggest-document-id-value="<%= suggest_doc_id %>"
         data-folder-suggest-folders-value="<%= suggest_folders_json %>"
         role="log"
         aria-label="Historique des messages"
         aria-live="polite"
         aria-atomic="false">
      <% if @messages.empty? %>
        <p class="text-center text-muted small py-5">
          Envoie ton premier message pour démarrer la conversation.
        </p>
      <% else %>
        <% prev_date = nil %>
        <% @messages.each do |message| %>
          <% msg_date = message.created_at.to_date %>
          <% if msg_date != prev_date %>
            <%= render "messages/date_separator", date: msg_date %>
            <% prev_date = msg_date %>
          <% end %>
          <%= render message %>
        <% end %>
      <% end %>
    </div>

    <div class="border-top p-3 bg-white">
      <%= turbo_frame_tag "new_message_form" do %>
        <span id="msg-hint" class="visually-hidden">
          Appuyez sur Entrée pour envoyer, Maj+Entrée pour un saut de ligne.
        </span>
        <%= simple_form_for [@conversation, @message],
                              html: {
                                "aria-label": "Envoyer un message",
                                data: {
                                  controller: "message-form",
                                  action: "turbo:submit-start->message-form#submitStart turbo:submit-end->message-form#submitEnd"
                                }
                              } do |f| %>
          <div class="d-flex gap-2 align-items-end">
            <%= f.text_area :content,
                            class: "form-control rounded-3 flex-grow-1",
                            placeholder: "Ton message...",
                            rows: 1,
                            required: true,
                            style: "resize: none; overflow-y: hidden; max-height: 150px;",
                            "aria-label": "Ton message",
                            "aria-describedby": "msg-hint",
                            "aria-required": "true",
                            data: {
                              controller: "textarea-autoresize",
                              action: "input->textarea-autoresize#resize keydown->textarea-autoresize#submitOnEnter",
                              voice_target: "input",
                              message_form_target: "input"
                            } %>
            <button type="button"
                    data-action="voice#toggle"
                    data-voice-target="micButton"
                    class="btn btn-outline-secondary flex-shrink-0 voice-btn"
                    aria-label="Dicter un message"
                    aria-pressed="false">
              <i class="fa-solid fa-microphone"></i>
              <span data-voice-target="timer" class="ms-1 small recording-timer" hidden></span>
            </button>
            <button type="submit"
                    class="btn btn-primary px-3 flex-shrink-0"
                    aria-label="Envoyer le message"
                    data-message-form-target="submit">
              <i class="fa-solid fa-paper-plane me-md-2" aria-hidden="true"></i>
              <span class="d-none d-md-inline">Envoyer</span>
            </button>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<div id="flashes" class="flashes" aria-live="polite" aria-atomic="true">
  <% if notice %>
    <div class="alert alert-info alert-dismissible fade show" role="alert" data-controller="flash">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
  <% end %>
  <% if alert %>
    <div class="alert alert-warning alert-dismissible fade show" role="alert" data-controller="flash">
      <%= alert %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
  <% end %>
</div>

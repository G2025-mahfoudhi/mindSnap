<nav class="navbar navbar-expand-md navbar-light bg-white sticky-top" aria-label="Navigation principale">
  <div class="container">
    <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
      <%= image_tag "logo_MindSnap.png", alt: "MindSnap", width: 32, height: 32, class: "me-2" %>
      <span class="fw-bold text-dark">MindSnap</span>
    <% end %>

    <% if user_signed_in? %>
      <div class="d-flex align-items-center ms-auto gap-2">

        <%# Mobile : dropdown nav (Recherche + Mon espace) %>
        <div class="dropdown d-flex d-md-none">
          <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-flex align-items-center justify-content-center"
                  style="width: 34px; height: 34px; padding: 0;"
                  type="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="Menu de navigation">
            <i class="fa-solid fa-bars"></i>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li>
              <%= link_to search_path, class: "dropdown-item" do %>
                <i class="fa-solid fa-magnifying-glass me-2"></i>Recherche
              <% end %>
            </li>
            <li>
              <%= link_to espaces_path, class: "dropdown-item" do %>
                <i class="fa-solid fa-layer-group me-2"></i>Mon espace
              <% end %>
            </li>
          </ul>
        </div>

        <%# Desktop : liens de navigation %>
        <ul class="navbar-nav flex-row gap-3 d-none d-md-flex">
          <li class="nav-item">
            <%= link_to search_path, class: "nav-link fs-6" do %>
              <i class="fa-solid fa-magnifying-glass me-1"></i> Recherche
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to "Mon espace", espaces_path, class: "nav-link fs-6" %>
          </li>
        </ul>

        <div class="dropdown">
          <button class="btn p-0 border-0 rounded-circle d-flex align-items-center justify-content-center overflow-hidden"
                  id="navbarDropdown"
                  data-bs-toggle="dropdown"
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-label="Mon compte"
                  style="width: 36px; height: 36px;">
            <% if current_user.avatar.attached? && current_user.avatar.blob.persisted? %>
              <img src="<%= avatar_url(current_user.avatar) %>" style="width: 36px; height: 36px; object-fit: cover; border-radius: 50%;" alt="Photo de profil">
            <% else %>
              <span class="d-flex align-items-center justify-content-center fw-semibold text-white w-100 h-100"
                    style="background-color: #549695; font-size: 13px; border-radius: 50%;">
                <%= current_user.first_name&.first&.upcase || "?" %><%= current_user.last_name&.first&.upcase %>
              </span>
            <% end %>
          </button>
          <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
            <%= link_to settings_path, class: "dropdown-item" do %>
              <i class="fa-solid fa-gear me-1"></i> Paramètres
            <% end %>
            <div class="dropdown-divider"></div>
            <%= link_to dashboard_path, class: "dropdown-item" do %>
              <i class="fa-solid fa-chart-line me-1"></i> Dashboard
            <% end %>
            <div class="dropdown-divider"></div>
            <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item text-danger" %>
          </div>
        </div>
      </div>
    <% else %>
      <%# Petit écran : dropdown flottant (même style que l'avatar) %>
      <div class="dropdown d-flex d-md-none ms-auto">
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="dropdown"
                aria-haspopup="true"
                aria-expanded="false"
                aria-label="Menu de navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="dropdown-menu dropdown-menu-end">
          <%= link_to "Connexion", new_user_session_path, class: "dropdown-item fs-6" %>
          <div class="dropdown-divider"></div>
          <%= link_to "Créer un compte", new_user_registration_path, class: "dropdown-item fw-semibold fs-6", style: "background-color: #3d7f7e !important; color: #fff !important;" %>
        </div>
      </div>

      <%# Grand écran : liens en ligne %>
      <div class="d-none d-md-flex align-items-center gap-4 ms-auto">
        <%= link_to "Connexion", new_user_session_path, class: "nav-link fs-6" %>
        <%= link_to "Créer un compte", new_user_registration_path, class: "btn btn-primary px-3" %>
      </div>
    <% end %>
  </div>
</nav>

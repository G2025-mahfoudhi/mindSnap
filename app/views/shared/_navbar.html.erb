<nav class="navbar navbar-expand-md navbar-light bg-white sticky-top" aria-label="Navigation principale">
  <div class="container">
    <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
      <%= image_tag "logo_MindSnap.png", alt: "MindSnap", width: 32, height: 32, class: "me-2" %>
      <span class="fw-bold text-dark">MindSnap</span>
    <% end %>

    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Menu de navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav ms-auto align-items-md-center gap-1">
        <%# Dropdown Fonctionnalités — icônes FA6 + séparateurs %>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" id="navbarDropdownFeatures" data-bs-toggle="dropdown" aria-expanded="false">
            Fonctionnalités
          </a>
          <ul class="dropdown-menu" aria-labelledby="navbarDropdownFeatures">
            <li><h6 class="dropdown-header"><i class="fa-solid fa-layer-group fa-fw me-1"></i> Gestion</h6></li>
            <li>
              <%= link_to documents_path, class: "dropdown-item" do %>
                <i class="fa-solid fa-file-lines fa-fw me-2"></i> Mes documents
              <% end %>
            </li>
            <li>
              <%= link_to folders_path, class: "dropdown-item" do %>
                <i class="fa-solid fa-folder-tree fa-fw me-2"></i> Mes dossiers
              <% end %>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li><h6 class="dropdown-header"><i class="fa-solid fa-microchip fa-fw me-1"></i> Intelligence</h6></li>
            <li>
              <%= link_to conversations_path, class: "dropdown-item" do %>
                <i class="fa-solid fa-robot fa-fw me-2"></i> Discuter avec l'IA
              <% end %>
            </li>
          </ul>
        </li>
        <li class="nav-item">
          <%= link_to "FAQ", faq_path, class: "nav-link" %>
        </li>
        <% if user_signed_in? %>
          <li class="nav-item">
            <%= link_to search_path, class: "nav-link" do %>
              <i class="fa-solid fa-magnifying-glass me-1"></i> Recherche
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to "Mon espace", espaces_path, class: "nav-link" %>
          </li>
          <li class="nav-item dropdown">
            <button class="btn p-0 border-0 rounded-circle d-flex align-items-center justify-content-center fw-semibold text-white"
                    id="navbarDropdown"
                    data-bs-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-label="Mon compte"
                    style="width: 36px; height: 36px; background-color: #549695; font-size: 13px;">
              <%= current_user.first_name&.first&.upcase || "?" %><%= current_user.last_name&.first&.upcase %>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
              <%= link_to "Paramètres", edit_user_registration_path, class: "dropdown-item" %>
              <div class="dropdown-divider"></div>
              <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %>
            </div>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Connexion", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item ms-md-2">
            <%= link_to "Créer un compte", new_user_registration_path, class: "btn btn-primary btn-sm px-3" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>

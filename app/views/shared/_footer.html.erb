<footer class="footer" role="contentinfo">
  <div class="footer__inner">
    <%= link_to root_path, class: "footer__brand" do %>
      <%= image_tag "logo_MindSnap.png", alt: "MindSnap", width: 20, height: 20 %>
      <span class="footer__name">MindSnap</span>
    <% end %>

    <nav class="footer__links" aria-label="Liens du footer">
      <%= link_to "Fonctionnalités", "#features" %>
      <%= link_to "Comment ça marche", "#features" %>
      <%= link_to "FAQ", faq_path %>
      <%= link_to "À propos", root_path(anchor: "features") %>
      <%= link_to "Équipe", equipe_path %>
      <%= link_to "Confidentialité", root_path %>
    </nav>

    <span class="footer__copy">
      &copy; <%= Date.today.year %> MindSnap
    </span>
  </div>
</footer>

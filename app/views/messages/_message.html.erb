<div class="d-flex mb-3 <%= message.role == 'user' ? 'justify-content-end' : 'justify-content-start' %>"
     id="<%= dom_id(message) %>"
     data-streaming="<%= message.streaming %>">
  <div class="rounded-3 px-3 py-2 <%= message.role == 'user' ? 'bg-primary text-white' : 'bg-light border' %>"
       style="max-width: 75%;">
    <div class="d-flex align-items-center gap-2 mb-1">
      <span class="small fw-semibold <%= message.role == 'user' ? 'text-white-50' : 'text-muted' %>">
        <%= message.role == 'user' ? 'Vous' : 'MindSnap AI' %>
      </span>
      <%# Bouton voice desactive tant que le stream n'est pas termine (pour eviter
          de lire un texte incomplet via TTS). %>
      <% if message.role == "assistant" && !message.streaming %>
        <button type="button"
                data-action="click->voice#speak"
                data-voice-text-param="<%= message.content %>"
                class="btn btn-sm btn-link p-0 tts-btn"
                aria-label="Lire la réponse à voix haute"
                style="font-size: 0.75rem;">
          <i class="fa-solid fa-volume-high"></i>
        </button>
      <% end %>
      <%# Indicateur de streaming (3 petits points qui clignotent). %>
      <% if message.streaming %>
        <span class="small text-muted" aria-label="Génération en cours">
          <i class="fa-solid fa-circle" style="font-size: 0.4rem; animation: stream-pulse 1s infinite;"></i>
          <i class="fa-solid fa-circle mx-1" style="font-size: 0.4rem; animation: stream-pulse 1s 0.2s infinite;"></i>
          <i class="fa-solid fa-circle" style="font-size: 0.4rem; animation: stream-pulse 1s 0.4s infinite;"></i>
        </span>
      <% end %>
    </div>
    <div class="markdown-content">
      <% if message.streaming %>
        <%= streaming_markdown(message.content.to_s) %>
      <% else %>
        <%= markdown(message.content.to_s) %>
      <% end %>
    </div>
    <div class="text-end mt-1" style="font-size: 0.68rem; opacity: 0.6;">
      <%= local_time(message.created_at, :time) %>
    </div>
  </div>
</div>

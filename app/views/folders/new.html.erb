<div class="folder-form-page">
  <%= link_to folders_path, class: "form-back-link" do %>
    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    Retour aux dossiers
  <% end %>

  <div class="form-header">
    <h1>Nouveau dossier</h1>
    <p>Organisez vos documents en créant un dossier.</p>
  </div>

  <div class="form-card">
    <%= form_with model: @folder, local: true do |f| %>
      <%= f.hidden_field :parent_id %>
      <div class="form-group">
        <%= f.label :name, "Nom du dossier" %>
        <%= f.text_field :name, placeholder: "Ex: Factures 2024", autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :description, "Description" %>
        <%= f.text_area :description, placeholder: "Une courte description (optionnel)" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Créer le dossier", class: "btn btn-primary" %>
        <%= link_to "Annuler", folders_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>

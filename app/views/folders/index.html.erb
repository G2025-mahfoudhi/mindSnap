<div class="folders-page">
  <div class="folders-header">
    <div class="folders-header-left">
      <span class="folders-header-icon">📁</span>
      <h1 class="folders-title">Mes dossiers</h1>
    </div>
    <%= link_to new_folder_path, class: "btn-new" do %>
      <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Nouveau dossier
    <% end %>
  </div>

  <hr class="folders-divider">

  <% if @folders.any? %>
    <div class="folders-grid">
      <% @folders.each do |folder| %>
        <%= link_to folder_path(folder), class: "folder-card" do %>
          <span class="folder-card-icon">📂</span>
          <div class="folder-card-name"><%= folder.name %></div>
          <% if folder.description.present? %>
            <div class="folder-card-desc"><%= folder.description %></div>
          <% else %>
            <div class="folder-card-desc">Aucune description</div>
          <% end %>
          <span class="folder-card-arrow">↗</span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <span class="empty-state-icon">📁</span>
      <p>Aucun dossier pour le moment</p>
      <%= link_to "Créer mon premier dossier", new_folder_path, class: "btn-new", style: "display:inline-flex;" %>
    </div>
  <% end %>
</div>


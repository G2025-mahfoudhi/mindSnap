<%# <h1>Folders#index</h1>
<p>Find me in app/views/folders/index.html.erb</p> %>

<h1>📁 Mes dossiers</h1>

<%= link_to "➕ Nouveau dossier", new_folder_path %>

<% if @folders.any? %>
  <ul>
    <% @folders.each do |folder| %>
      <%= link_to folder.name, folder_path(folder) %>
    <% end %>
  </ul>
<% else %>
  <p>Aucun dossier pour le moment</p>
<% end %>

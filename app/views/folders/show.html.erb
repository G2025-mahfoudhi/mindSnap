<% content_for :body_class, "overflow-hidden" %>
<% content_for :main_style, "height: calc(var(--vh, 100vh) - var(--navbar-height, 56px) - var(--footer-height, 60px)); overflow: hidden;" %>
<div class="d-flex" style="height: calc(var(--vh, 100vh) - var(--navbar-height, 56px) - var(--footer-height, 60px));">

  <%= render "documents/sidebar",
             folders: @sidebar_folders,
             documents_without_folder: @documents_without_folder,
             current_document: nil %>

  <main class="flex-grow-1 overflow-auto p-4">
  <div class="folder-show-page">

  <%= link_to espaces_path,
              class: "d-inline-flex align-items-center gap-2 text-decoration-none small mb-3",
              style: "color: #5a6370;" do %>
    <i class="fa-solid fa-arrow-left fa-xs" aria-hidden="true"></i>
    Mon espace
  <% end %>

  <div class="show-header">
    <div class="show-header-left">
      <span class="show-header-icon" aria-hidden="true">📂</span>
      <div>
        <h1 class="show-title"><%= @folder.name %></h1>
        <% if @folder.description.present? %>
          <p class="show-desc"><%= @folder.description %></p>
        <% else %>
          <p class="show-desc" style="font-style:italic;">Aucune description</p>
        <% end %>
      </div>
    </div>

    <div class="show-actions">
      <%= button_to chat_folder_path(@folder),
            method: :post,
            class: "btn btn-primary btn-sm",
            data: { turbo: false },
            aria: { label: "Discuter avec ce dossier" } do %>
        <i class="fa-solid fa-robot me-1"></i> Discuter
      <% end %>
      <%= link_to "Sous-dossier", new_folder_path(parent_id: @folder.id), class: "btn btn-primary btn-sm" %>
      <%= link_to "Modifier", edit_folder_path(@folder), class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "Supprimer", folder_path(@folder),
            data: { turbo_method: :delete, turbo_confirm: "Supprimer ce dossier ?" },
            class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>

  <hr class="show-divider">

  <%# ——— SOUS-DOSSIERS ——— %>
  <div class="section-block">
    <div class="section-header">
      <h2 class="section-title">
        <span aria-hidden="true">📂</span> Sous-dossiers
      </h2>
      <span class="section-count"><%= @children.count %></span>
    </div>

    <% if @children.any? %>
      <div class="item-grid">
        <% @children.each do |child| %>
          <%= link_to folder_path(child), class: "subfolder-card" do %>
            <span class="subfolder-card-icon" aria-hidden="true">📁</span>
            <div class="subfolder-card-name"><%= child.name %></div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-block">Aucun sous-dossier</div>
    <% end %>
  </div>

  <%# ——— DOCUMENTS ——— %>
  <div class="section-block">
    <div class="section-header">
      <h2 class="section-title">
        <span aria-hidden="true">📄</span> Documents
      </h2>
      <div class="d-flex align-items-center gap-2">
        <span class="section-count"><%= @documents.count %></span>
        <%= link_to "Nouveau document", new_document_path(folder_id: @folder.id), class: "btn btn-primary btn-sm" %>
      </div>
    </div>

    <% if @documents.any? %>
      <div class="doc-list">
        <% @documents.each do |doc| %>
          <%= link_to document_path(doc), class: "doc-item" do %>
            <span class="doc-item-icon" aria-hidden="true">📄</span>
            <span class="doc-item-title"><%= doc.title %></span>
            <% if doc.document_type.present? %>
              <span class="doc-item-type"><%= doc.document_type %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state empty-state--card">
        <div class="empty-state__illustration">
          <%= image_tag "empty/folder.svg", alt: "" %>
        </div>
        <h3 class="empty-state__title">Dossier vide</h3>
        <p class="empty-state__text">
          Aucun document dans ce dossier pour l'instant.
        </p>
        <div class="empty-state__action">
          <%= link_to "Ajouter un document", new_document_path(folder_id: @folder.id), class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>

</div>
  </main>
</div>

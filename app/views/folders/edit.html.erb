<div class="folder-form-page">
  <%= link_to folder_path(@folder), class: "form-back-link" do %>
    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    Retour au dossier
  <% end %>

  <div class="form-header">
    <h1>Modifier le dossier</h1>
    <p>Mettez à jour le nom ou la description.</p>
  </div>

  <div class="form-card">
    <%= form_with model: @folder, local: true do |f| %>
      <%= f.hidden_field :parent_id %>
      <div class="form-group">
        <%= f.label :name, "Nom du dossier" %>
        <%= f.text_field :name, autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :description, "Description" %>
        <%= f.text_area :description, placeholder: "Une courte description (optionnel)" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Enregistrer", class: "btn btn-primary" %>
        <%= link_to "Annuler", folder_path(@folder), class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<%# ============================================================
  Page : Modifier le profil (Devise registrations/edit)
  Layout 1 colonne centrée (pas de sidebar, c'est un réglage).
  Champs : Prénom, Nom, Email, Nouveau MDP (optionnel),
           Confirmation, MDP actuel, Supprimer compte.
  Cf. DECISIONS.md #008 (first/last name)
============================================================ %>

<div class="container py-4" style="max-width: 700px;">
  <div class="card mx-auto">
    <div class="card-header text-center">
      <h2 class="h3 mb-1"><strong>Modifier mon profil</strong></h2>
      <p class="text-muted small mb-0">Tes informations personnelles.</p>
    </div>
    <div class="card-body">

      <%# Formulaire Devise — Simple Form gère le markup Bootstrap %>
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), defaults: { required: false }, html: { method: :put, multipart: true }) do |f| %>
        <%= f.error_notification %>

        <div class="form-inputs">
          <%# Photo de profil %>
          <% has_avatar = resource.persisted? && resource.avatar.attached? && resource.avatar.blob.persisted? %>

          <div class="mb-4 text-center" data-controller="avatar-preview">

            <%# Avatar + dropdown Facebook-style %>
            <div class="dropdown d-inline-block mb-2">
              <div class="avatar-upload-wrapper" data-bs-toggle="dropdown" data-bs-auto-close="outside" style="cursor: pointer;">
                <% if has_avatar %>
                  <img src="<%= avatar_url(resource.avatar) %>"
                       class="avatar-upload-img"
                       alt="Photo de profil"
                       data-avatar-preview-target="preview">
                <% else %>
                  <div class="avatar-upload-initials" data-avatar-preview-target="placeholder">
                    <span><%= resource.first_name&.first&.upcase %><%= resource.last_name&.first&.upcase %></span>
                  </div>
                  <img src="" class="avatar-upload-img d-none" alt="Aperçu" data-avatar-preview-target="preview">
                <% end %>
                <div class="avatar-camera-badge">
                  <i class="fa-solid fa-camera"></i>
                </div>
              </div>

              <ul class="dropdown-menu shadow-sm" style="min-width: 230px;">
                <% if has_avatar %>
                  <li>
                    <button type="button" class="dropdown-item py-2" data-bs-toggle="modal" data-bs-target="#avatarModal">
                      <i class="fa-regular fa-image me-2 text-muted"></i>Voir la photo de profil
                    </button>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                <% end %>
                <li>
                  <button type="button" class="dropdown-item py-2" data-action="click->avatar-preview#triggerInput">
                    <i class="fa-solid fa-camera me-2 text-muted"></i>Modifier la photo de profil
                  </button>
                </li>
                <% if has_avatar %>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li>
                    <%= link_to avatar_path,
                                data: { turbo_method: :delete, turbo_confirm: "Supprimer définitivement ta photo de profil ?" },
                                class: "dropdown-item py-2 text-danger" do %>
                      <i class="fa-solid fa-trash me-2"></i>Supprimer la photo de profil
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>

            <%# Input caché %>
            <%= f.input :avatar,
                        label: false,
                        as: :file,
                        wrapper: false,
                        input_html: {
                          accept: "image/*",
                          class: "d-none",
                          data: { "avatar-preview-target": "input", action: "change->avatar-preview#preview" }
                        } %>
          </div>

          <%# Modal — voir la photo en grand %>
          <% if has_avatar %>
            <div class="modal fade" id="avatarModal" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0" style="background: rgba(0,0,0,0.85);">
                  <div class="modal-body text-center p-4 position-relative">
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal"></button>
                    <img src="<%= avatar_url(resource.avatar) %>" class="rounded-circle" style="width: 280px; height: 280px; object-fit: cover;" alt="Photo de profil">
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <%# Prénom + Nom sur la même ligne %>
          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.input :first_name,
                          required: false,
                          autofocus: true,
                          label: "Prénom",
                          input_html: { autocomplete: "given-name" } %>
            </div>
            <div class="col-md-6 mb-3">
              <%= f.input :last_name,
                          required: false,
                          label: "Nom",
                          input_html: { autocomplete: "family-name" } %>
            </div>
          </div>

          <%= f.input :email, required: false %>

          <%# Message si email en attente de confirmation %>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <p class="text-muted small">En attente de confirmation pour : <%= resource.unconfirmed_email %></p>
          <% end %>

          <%# Mot de passe (optionnel) %>
          <%= f.input :password,
                      label: "Nouveau mot de passe",
                      hint: "Laisse vide si tu ne veux pas le changer",
                      required: false,
                      input_html: { autocomplete: "new-password" } %>

          <%= f.input :password_confirmation,
                      label: "Confirmation du nouveau mot de passe",
                      required: false,
                      input_html: { autocomplete: "new-password" } %>

          <%# Mot de passe actuel (obligatoire pour toute modification) %>
          <%= f.input :current_password,
                      label: "Mot de passe actuel",
                      hint: "Nous avons besoin de ton mot de passe actuel pour confirmer les changements",
                      required: false,
                      input_html: { autocomplete: "current-password" } %>
        </div>

      <div class="d-flex gap-2 mt-5">
        <%= f.button :submit, "Mettre à jour", class: "btn btn-primary", style: "width: 70%;" %>
        <%= link_to "← Retour", :back, class: "btn btn-outline-secondary flex-grow-1" %>
      </div>
      <% end %>

      <%# ============================================================
        Zone dangereuse : suppression du compte.
        Séparée visuellement par un divider.
        Bouton danger outline pour éviter les clics accidentels.
      ============================================================ %>

      <div class="auth-card__danger-zone">
        <h3 class="danger-zone__label">Zone dangereuse</h3>
        <%= button_to "Supprimer mon compte",
                      registration_path(resource_name),
                      data: { confirm: "Es-tu sûr ? Cette action est irréversible.", turbo_confirm: "Es-tu sûr ? Cette action est irréversible." },
                      method: :delete,
                      class: "btn btn-outline-danger btn-sm" %>
      </div>


    </div>
  </div>
</div>

<%# ============================================================
  Partial : devise/shared/_links
  Liens de navigation entre les pages Devise
  (connexion, inscription, mot de passe oublié, etc.).

  Modifications par rapport au template Devise par défaut :
  - Suppression des balises <p> autour de chaque lien
    (le padding est géré par .auth-card__footer dans le parent)
  - Liens en display:block pour un espacement vertical propre
  - Pas de bouton pour OmniAuth (non utilisé)

  Ce partial est rendu dans .auth-card__footer qui gère
  le centrage et la taille de police.
============================================================ %>

<%# Lien vers la connexion (affiché partout sauf sur login) %>
<%- if controller_name != 'sessions' %>
  <%= link_to "Se connecter", new_session_path(resource_name), class: "d-block mb-2" %>
<% end %>

<%# Lien vers l'inscription (affiché si l'inscription est activée) %>
<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to "Créer un compte", new_registration_path(resource_name), class: "d-block mb-2" %>
<% end %>

<%# Mot de passe oublié (affiché sur login, pas sur signup ni reset) %>
<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "d-block mb-2" %>
<% end %>

<%# Renvoyer la confirmation %>
<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <%= link_to "Renvoyer les instructions de confirmation", new_confirmation_path(resource_name), class: "d-block mb-2" %>
<% end %>

<%# Débloquer le compte %>
<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <%= link_to "Renvoyer les instructions de déblocage", new_unlock_path(resource_name), class: "d-block mb-2" %>
<% end %>

<%# OmniAuth — non utilisé pour MindSnap, laissé pour compatibilité %>
<%#- if devise_mapping.omniauthable? %>
  <%#- resource_class.omniauth_providers.each do |provider| %>
    <%#= button_to "Se connecter avec #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "d-block mb-2" %>
  <%# end %>
<%# end %>
<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <%= form_for "Login",
      url: omniauth_authorize_path(resource_name, provider),
      method: :post,
      data: {turbo: "false"} do |f| %>
        <%= f.submit "Se connecter avec Google", class: "btn btn-primary" %>
    <% end %>
  <% end %>
<% end %>

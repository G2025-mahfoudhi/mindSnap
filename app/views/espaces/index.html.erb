<% content_for :title, "Mon espace — MindSnap" %>
<% content_for :body_class, "overflow-hidden" %>
<% content_for :main_style, "height: calc(100vh - 56px); overflow: hidden;" %>
<div class="d-flex" style="height: calc(100vh - 56px);">

  <%= render "documents/sidebar",
             folders: @sidebar_folders,
             documents_without_folder: @documents_without_folder,
             current_document: nil %>

  <main class="flex-grow-1 d-flex flex-column overflow-hidden" aria-label="Mon espace">

    <%# ——— HEADER STICKY ——— %>
    <div style="position: sticky; top: 0; z-index: 10; flex-shrink: 0;
                padding: 1rem 1.5rem; border-bottom: 1px solid #ebebeb; background: #fff;">
      <div class="d-flex align-items-center gap-2">
        <i class="fa-solid fa-layer-group" style="color: #3d7f7e; font-size: 1.1rem;" aria-hidden="true"></i>
        <h1 style="font-size: 1.2rem; font-weight: 600; color: #1a1a1a; margin: 0;">Mon espace</h1>
      </div>
    </div>

    <%# ——— CONTENU SCROLLABLE ——— %>
    <div class="flex-grow-1" style="overflow-y: auto; padding: 1.5rem; padding-bottom: 5rem;">

      <% if @folders.any? %>
        <p class="text-muted text-uppercase fw-semibold mb-3" style="font-size: 0.75rem; letter-spacing: 0.06em;">
          Dossiers
        </p>
        <div class="row g-3 mb-4">
          <% @folders.each do |folder| %>
            <div class="col-sm-6 col-md-4 col-lg-3">
              <%= render "espaces/folder_card", folder: folder %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @documents_without_folder.any? %>
        <p class="text-muted text-uppercase fw-semibold mb-3" style="font-size: 0.75rem; letter-spacing: 0.06em;">
          Documents sans dossier
        </p>
        <div class="row g-3">
          <% @documents_without_folder.each do |document| %>
            <div class="col-sm-6 col-lg-4">
              <%= render "shared/document_card", document: document %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @folders.empty? && @documents_without_folder.empty? %>
        <div class="text-center py-5">
          <i class="fa-solid fa-folder-open fa-3x mb-3" style="color: #f0ad4e;" aria-hidden="true"></i>
          <p class="text-muted mb-0">Aucun contenu pour le moment.</p>
        </div>
      <% end %>
    </div>
  </main>

</div>

<% content_for :title, "Mon espace — MindSnap" %>
<div class="d-flex" style="min-height: calc(100vh - 56px);">

  <%= render "documents/sidebar",
             folders: @folders,
             documents_without_folder: @documents_without_folder,
             current_document: nil %>

  <main class="flex-grow-1 overflow-auto p-4" aria-label="Mon espace">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">Mon espace</h1>
    </div>

    <% if @folders.any? %>
      <p class="text-muted text-uppercase fw-semibold mb-3" style="font-size: 0.75rem; letter-spacing: 0.06em;">
        Dossiers
      </p>
      <div class="row g-3 mb-4">
        <% @folders.each do |folder| %>
          <div class="col-sm-6 col-md-4 col-lg-3">
            <%= render "espaces/folder_card", folder: folder %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @documents_without_folder.any? %>
      <p class="text-muted text-uppercase fw-semibold mb-3" style="font-size: 0.75rem; letter-spacing: 0.06em;">
        Documents sans dossier
      </p>
      <div class="row g-3">
        <% @documents_without_folder.each do |document| %>
          <div class="col-sm-6 col-lg-4">
            <%= render "shared/document_card", document: document %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @folders.empty? && @documents_without_folder.empty? %>
      <div class="text-center py-5">
        <i class="fa-solid fa-folder-open fa-3x mb-3" style="color: #f0ad4e;" aria-hidden="true"></i>
        <p class="text-muted mb-0">Aucun contenu pour le moment.</p>
      </div>
    <% end %>
  </main>

</div>

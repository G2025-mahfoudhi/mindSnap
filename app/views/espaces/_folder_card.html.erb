<%= link_to folder_path(folder), class: "card h-100 border-0 text-decoration-none text-dark", style: "box-shadow: 0 4px 24px rgba(0,0,0,.06);" do %>
  <div class="card-body d-flex align-items-center gap-3">
    <i class="fa-solid fa-folder fa-xl flex-shrink-0" style="color: #f0ad4e;" aria-hidden="true"></i>
    <div style="min-width: 0;">
      <div class="fw-semibold text-truncate"><%= folder.name %></div>
      <small class="text-muted">
        <%= folder.documents.size %> document<%= folder.documents.size != 1 ? "s" : "" %>
      </small>
    </div>
    <i class="fa-solid fa-chevron-right fa-xs ms-auto" style="color: #ccc;" aria-hidden="true"></i>
  </div>
<% end %>

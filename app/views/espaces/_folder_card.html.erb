<div class="card h-100 border-0" style="box-shadow: 0 4px 24px rgba(0,0,0,.06);">
  <div class="card-body d-flex align-items-center gap-3">
    <div class="rounded d-flex align-items-center justify-content-center flex-shrink-0"
         style="width:40px; height:40px; background-color:#fff3cd;">
      <i class="fa-solid fa-folder fa-lg" style="color:#f0ad4e;"></i>
    </div>
    <div style="min-width: 0;">
      <div class="fw-semibold text-truncate"><%= folder.name %></div>
      <small class="text-muted">
        <%= folder.documents.size %> document<%= folder.documents.size != 1 ? "s" : "" %>
      </small>
    </div>
  </div>
  <div class="card-footer bg-transparent border-0 pt-0 d-flex align-items-center gap-2">
    <%= link_to new_document_path(folder_id: folder.id),
                class: "btn btn-sm btn-outline-primary",
                aria: { label: "Ajouter un document dans #{folder.name}" } do %>
      <i class="fa-solid fa-plus fa-xs"></i>
    <% end %>
    <% if folder.documents.any? %>
      <div class="ms-auto d-flex flex-wrap gap-1">
        <% folder.documents.first(3).each do |doc| %>
          <%= link_to doc.title.truncate(12), document_path(doc),
                      class: "badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 text-decoration-none" %>
        <% end %>
        <% if folder.documents.size > 3 %>
          <span class="badge bg-light text-muted border">+<%= folder.documents.size - 3 %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Mind Snap" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Mind Snap">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= meta_description %>">

    <%# Open Graph %>
    <meta property="og:title" content="<%= meta_title %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:image" content="<%= meta_image %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:site_name" content="MindSnap">
    <meta property="og:locale" content="fr_FR">

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="<%= ::DEFAULT_META["twitter_account"] %>">
    <meta name="twitter:title" content="<%= meta_title %>">
    <meta name="twitter:description" content="<%= meta_description %>">
    <meta name="twitter:image" content="<%= meta_image %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="padding-bottom: 3rem;" class="<%= content_for(:body_class) %>">
    <a href="#main-content" class="visually-hidden-focusable">Aller au contenu principal</a>
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>

    <div id="main-content" style="<%= content_for(:main_style) %>">
      <%= yield %>
    </div>
    <%= render "shared/conversation_actions" %>
    <%= render "shared/footer" %>
  </body>
</html>
